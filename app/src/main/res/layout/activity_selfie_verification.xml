<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/screen_background"
        android:paddingHorizontal="@dimen/screen_padding">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="@dimen/back_icon_size"
            android:layout_height="@dimen/back_icon_size"
            android:layout_marginTop="@dimen/spacing_lg"
            android:contentDescription="@string/cd_back"
            android:src="@drawable/ic_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:text="@string/selfie_title"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/ivBack"
            app:layout_constraintStart_toEndOf="@id/ivBack"
            app:layout_constraintTop_toTopOf="@id/ivBack" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollContent"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/spacing_lg"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:paddingBottom="@dimen/spacing_lg"
            app:layout_constraintBottom_toTopOf="@id/bottomActions"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivBack">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_selfie_guidelines"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/selfie_guidelines_title"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="@dimen/check_size"
                            android:layout_height="@dimen/check_size"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_guideline_check" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_sm"
                            android:layout_weight="1"
                            android:text="@string/selfie_guideline_lighting"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="@dimen/check_size"
                            android:layout_height="@dimen/check_size"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_guideline_check" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_sm"
                            android:layout_weight="1"
                            android:text="@string/selfie_guideline_glasses"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="@dimen/check_size"
                            android:layout_height="@dimen/check_size"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_guideline_check" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_sm"
                            android:layout_weight="1"
                            android:text="@string/selfie_guideline_centered"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="@dimen/check_size"
                            android:layout_height="@dimen/check_size"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_guideline_check" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_sm"
                            android:layout_weight="1"
                            android:text="@string/selfie_guideline_expression"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/selfie_frame_height"
                    android:layout_marginTop="@dimen/spacing_xl"
                    android:background="@drawable/bg_selfie_frame">

                    <ImageView
                        android:id="@+id/ivSelfiePreview"
                        android:layout_width="@dimen/selfie_placeholder_size"
                        android:layout_height="@dimen/selfie_placeholder_size"
                        android:layout_gravity="center"
                        android:contentDescription="@string/selfie_title"
                        android:src="@drawable/ic_person" />
                </FrameLayout>

                <LinearLayout
                    android:id="@+id/captureHints"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvPositionHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_selfie_hint_pill"
                        android:paddingHorizontal="@dimen/spacing_lg"
                        android:paddingVertical="@dimen/spacing_sm"
                        android:text="@string/selfie_position_hint"
                        android:textColor="@color/brand_primary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_lg"
                        android:background="@drawable/bg_info_filled"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_md">

                        <ImageView
                            android:layout_width="@dimen/info_icon_size"
                            android:layout_height="@dimen/info_icon_size"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_info" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_sm"
                            android:layout_weight="1"
                            android:text="@string/selfie_identity_hint"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/reviewStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xl"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <ImageView
                        android:layout_width="@dimen/selfie_captured_icon_size"
                        android:layout_height="@dimen/selfie_captured_icon_size"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_check_circle" />

                    <TextView
                        android:id="@+id/tvPhotoCaptured"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="@string/selfie_photo_captured"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <LinearLayout
            android:id="@+id/bottomActions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_xl"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <Button
                android:id="@+id/btnCapture"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:background="@drawable/bg_button_primary"
                android:drawablePadding="@dimen/spacing_sm"
                android:drawableStart="@drawable/ic_camera"
                android:gravity="center"
                android:paddingHorizontal="@dimen/spacing_xl"
                android:text="@string/selfie_capture"
                android:textAllCaps="false"
                android:textColor="@color/text_on_brand"
                android:textStyle="bold"
                app:backgroundTint="@null"
                app:drawableTint="@color/icon_on_brand" />

            <Button
                android:id="@+id/btnContinue"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:background="@drawable/bg_button_primary"
                android:text="@string/continue_button"
                android:textAllCaps="false"
                android:textColor="@color/text_on_brand"
                android:textStyle="bold"
                android:visibility="gone"
                app:backgroundTint="@null"
                tools:visibility="visible" />

            <Button
                android:id="@+id/btnRetake"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/spacing_md"
                android:background="@drawable/bg_button_outline_primary"
                android:drawablePadding="@dimen/spacing_sm"
                android:drawableStart="@drawable/ic_camera"
                android:gravity="center"
                android:paddingHorizontal="@dimen/spacing_xl"
                android:text="@string/selfie_retake"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:visibility="gone"
                app:backgroundTint="@null"
                app:drawableTint="@color/text_primary"
                tools:visibility="visible" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
