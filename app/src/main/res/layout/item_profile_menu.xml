<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_md"
        android:background="@drawable/bg_home_card"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_lg">

        <ImageView
            android:id="@+id/ivMenuIcon"
            android:layout_width="@dimen/profile_menu_icon"
            android:layout_height="@dimen/profile_menu_icon"
            android:background="@drawable/bg_circle_brand_soft"
            android:contentDescription="@null"
            android:padding="@dimen/spacing_sm"
            android:src="@drawable/ic_document"
            app:tint="@color/brand_primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvMenuTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="Documents" />

            <TextView
                android:id="@+id/tvMenuSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                tools:text="KYC &amp; verification status" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvMenuBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:background="@drawable/bg_badge_approved"
            android:paddingHorizontal="@dimen/spacing_sm"
            android:paddingVertical="@dimen/spacing_xs"
            android:text="@string/profile_badge_verified"
            android:textColor="@color/status_approved"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone"
            tools:visibility="visible" />

        <ImageView
            android:layout_width="@dimen/icon_size"
            android:layout_height="@dimen/icon_size"
            android:contentDescription="@null"
            android:src="@drawable/ic_chevron_right"
            app:tint="@color/text_muted" />
    </LinearLayout>
</layout>
