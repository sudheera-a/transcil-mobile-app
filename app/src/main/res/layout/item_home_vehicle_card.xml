<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_home_card"
        android:orientation="vertical"
        android:paddingTop="@dimen/spacing_lg"
        android:paddingBottom="@dimen/spacing_lg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_lg">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvVehicleModel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="Ellod Elite" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvVehicleType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_vehicle_type"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <ImageView
                        android:layout_width="@dimen/spacing_md"
                        android:layout_height="@dimen/spacing_md"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_star" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_xs"
                        android:text="@string/home_vehicle_rating"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvVehicleStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_available"
                android:paddingHorizontal="@dimen/spacing_md"
                android:paddingVertical="@dimen/spacing_sm"
                android:text="@string/home_vehicle_available"
                android:textColor="@color/brand_primary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Full-bleed media: image fills the rounded container edge-to-edge -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/home_vehicle_image_height"
            android:layout_marginHorizontal="@dimen/spacing_lg"
            android:layout_marginTop="@dimen/spacing_md"
            android:background="@drawable/bg_rounded_media"
            android:clipToOutline="true">

            <ImageView
                android:id="@+id/ivVehicleImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/home_vehicle_type"
                android:padding="@dimen/spacing_sm"
                android:scaleType="centerCrop"
                android:src="@drawable/scooter_onboarding" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_lg">

            <Button
                android:id="@+id/btnVehicleDetails"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:layout_weight="1"
                android:background="@drawable/bg_button_primary"
                android:drawableStart="@drawable/ic_info"
                android:drawablePadding="@dimen/spacing_sm"
                android:drawableTint="@color/text_on_brand"
                android:gravity="center"
                android:includeFontPadding="false"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="0dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:paddingHorizontal="@dimen/spacing_md"
                android:text="@string/home_vehicle_details"
                android:textAllCaps="false"
                android:textColor="@color/text_on_brand"
                app:backgroundTint="@null"

                />

            <Button
                android:id="@+id/btnVehicleSelect"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_outline_brand"
                android:text="@string/home_vehicle_select"
                android:textAllCaps="false"
                android:textColor="@color/brand_primary"
                app:backgroundTint="@null" />
        </LinearLayout>
    </LinearLayout>
</layout>
