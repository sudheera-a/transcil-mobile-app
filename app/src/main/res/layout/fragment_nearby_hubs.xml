<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/home_surface"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_lg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="@dimen/back_icon_size"
                android:layout_height="@dimen/back_icon_size"
                android:contentDescription="@string/nearby_hubs_back_cd"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back"
                app:tint="@color/text_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_weight="1"
                android:text="@string/nearby_hubs_title"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/mapPlaceholder"
            android:layout_width="match_parent"
            android:layout_height="@dimen/nearby_hubs_map_height"
            android:layout_marginTop="@dimen/spacing_lg"
            android:background="@drawable/bg_map_placeholder"
            android:contentDescription="@string/nearby_hubs_map_cd"
            android:clipToOutline="true">

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/spacing_sm"
                android:layout_gravity="center_vertical"
                android:layout_marginHorizontal="@dimen/spacing_xl"
                android:background="@drawable/bg_map_road_line" />

            <View
                android:layout_width="@dimen/spacing_sm"
                android:layout_height="match_parent"
                android:layout_gravity="center_horizontal"
                android:layout_marginVertical="@dimen/spacing_xl"
                android:background="@drawable/bg_map_road_line" />

            <ImageView
                android:layout_width="@dimen/nearby_hubs_map_pin"
                android:layout_height="@dimen/nearby_hubs_map_pin"
                android:layout_gravity="start|top"
                android:layout_marginStart="@dimen/spacing_xl"
                android:layout_marginTop="@dimen/spacing_lg"
                android:contentDescription="@null"
                android:src="@drawable/ic_map_pin" />

            <ImageView
                android:layout_width="@dimen/nearby_hubs_map_pin"
                android:layout_height="@dimen/nearby_hubs_map_pin"
                android:layout_gravity="end|top"
                android:layout_marginTop="@dimen/spacing_xl"
                android:layout_marginEnd="@dimen/spacing_xl"
                android:contentDescription="@null"
                android:src="@drawable/ic_map_pin" />

            <ImageView
                android:layout_width="@dimen/nearby_hubs_map_pin"
                android:layout_height="@dimen/nearby_hubs_map_pin"
                android:layout_gravity="center_horizontal|top"
                android:layout_marginTop="@dimen/spacing_md"
                android:contentDescription="@null"
                android:src="@drawable/ic_map_pin" />

            <ImageView
                android:layout_width="@dimen/nearby_hubs_map_pin"
                android:layout_height="@dimen/nearby_hubs_map_pin"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="@dimen/spacing_lg"
                android:contentDescription="@null"
                android:src="@drawable/ic_map_pin" />

            <ImageView
                android:layout_width="@dimen/icon_size"
                android:layout_height="@dimen/icon_size"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/spacing_xl"
                android:contentDescription="@null"
                android:src="@drawable/ic_nav_arrow" />

            <ImageView
                android:id="@+id/btnRecenter"
                android:layout_width="@dimen/icon_tile_size"
                android:layout_height="@dimen/icon_tile_size"
                android:layout_gravity="bottom|end"
                android:layout_margin="@dimen/spacing_md"
                android:background="@drawable/bg_home_quick_tile"
                android:contentDescription="@string/nearby_hubs_recenter_cd"
                android:padding="@dimen/spacing_sm"
                android:src="@drawable/ic_map_recenter"
                app:tint="@color/text_primary" />
        </FrameLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/nearby_hubs_swap_stations"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvStations"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/spacing_md"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/spacing_lg"
            tools:listitem="@layout/item_swap_station" />
    </LinearLayout>
</layout>
