<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/home_surface">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollContent"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:paddingHorizontal="@dimen/screen_padding"
            android:paddingTop="@dimen/spacing_lg"
            android:paddingBottom="@dimen/spacing_lg"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvGreeting"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            tools:text="Good Morning, Sai" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="@string/home_greeting_subtitle"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/btnNotifications"
                        android:layout_width="@dimen/home_quick_icon_size"
                        android:layout_height="@dimen/home_quick_icon_size"
                        android:background="@drawable/bg_home_quick_tile"
                        android:clickable="true"
                        android:contentDescription="@string/home_notifications_cd"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless">

                        <ImageView
                            android:layout_width="@dimen/icon_size"
                            android:layout_height="@dimen/icon_size"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_notifications"
                            app:tint="@color/brand_primary" />

                        <View
                            android:id="@+id/notificationDot"
                            android:layout_width="@dimen/home_notification_dot"
                            android:layout_height="@dimen/home_notification_dot"
                            android:layout_gravity="top|end"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:background="@drawable/bg_notification_dot" />
                    </FrameLayout>
                </LinearLayout>

                <!-- Pending frame: profile + KYC badge -->
                <LinearLayout
                    android:id="@+id/cardProfilePending"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:background="@drawable/bg_home_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_lg"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <ImageView
                        android:layout_width="@dimen/home_quick_icon_size"
                        android:layout_height="@dimen/home_quick_icon_size"
                        android:background="@drawable/bg_circle_brand_soft"
                        android:contentDescription="@null"
                        android:padding="@dimen/spacing_sm"
                        android:src="@drawable/ic_person" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvProfileName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:text="User Name" />

                        <TextView
                            android:id="@+id/tvTranscilId"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            tools:text="Transcil ID: TC-1001" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvKycBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge_pending"
                        android:paddingHorizontal="@dimen/spacing_md"
                        android:paddingVertical="@dimen/spacing_sm"
                        android:text="@string/home_status_pending"
                        android:textColor="@color/status_pending"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Approved frame: active vehicle hero -->
                <LinearLayout
                    android:id="@+id/cardActiveVehicle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:background="@drawable/bg_home_card"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg"
                    android:visibility="gone"
                    tools:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/home_active_plate"
                                android:textColor="@color/text_primary"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_xs"
                                android:text="@string/home_active_model"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_badge_approved"
                            android:paddingHorizontal="@dimen/spacing_md"
                            android:paddingVertical="@dimen/spacing_sm"
                            android:text="@string/home_active_badge"
                            android:textColor="@color/status_approved"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:drawableStart="@drawable/ic_bolt"
                            android:drawablePadding="@dimen/spacing_sm"
                            android:text="@string/home_battery_percent"
                            android:textColor="@color/brand_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_battery_range"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:drawableStart="@drawable/ic_location"
                            android:drawablePadding="@dimen/spacing_sm"
                            android:gravity="center_vertical"
                            android:text="@string/home_hub_name"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableStart="@drawable/ic_calendar"
                            android:drawablePadding="@dimen/spacing_sm"
                            android:gravity="center_vertical"
                            android:text="@string/home_due_date"
                            android:textColor="@color/alert_warning"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Quick icons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/actionBatterySwap"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="@dimen/home_quick_icon_size"
                            android:layout_height="@dimen/home_quick_icon_size"
                            android:background="@drawable/bg_home_quick_tile">

                            <ImageView
                                android:layout_width="@dimen/home_quick_glyph_size"
                                android:layout_height="@dimen/home_quick_glyph_size"
                                android:layout_gravity="center"
                                android:contentDescription="@string/home_quick_battery_swap"
                                android:src="@drawable/ic_home_battery_swap" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:gravity="center"
                            android:lineSpacingExtra="1dp"
                            android:text="@string/home_quick_battery_swap"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/actionNavigateQuick"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="@dimen/home_quick_icon_size"
                            android:layout_height="@dimen/home_quick_icon_size"
                            android:background="@drawable/bg_home_quick_tile">

                            <ImageView
                                android:layout_width="@dimen/home_quick_glyph_size"
                                android:layout_height="@dimen/home_quick_glyph_size"
                                android:layout_gravity="center"
                                android:contentDescription="@string/home_quick_navigate"
                                android:src="@drawable/ic_home_navigate" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:gravity="center"
                            android:text="@string/home_quick_navigate"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/actionHubs"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="@dimen/home_quick_icon_size"
                            android:layout_height="@dimen/home_quick_icon_size"
                            android:background="@drawable/bg_home_quick_tile">

                            <ImageView
                                android:layout_width="@dimen/home_quick_glyph_size"
                                android:layout_height="@dimen/home_quick_glyph_size"
                                android:layout_gravity="center"
                                android:contentDescription="@string/home_quick_hubs"
                                android:src="@drawable/ic_home_nearby_hubs" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:gravity="center"
                            android:lineSpacingExtra="1dp"
                            android:text="@string/home_quick_hubs"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/actionExtend"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="@dimen/home_quick_icon_size"
                            android:layout_height="@dimen/home_quick_icon_size"
                            android:background="@drawable/bg_home_quick_tile">

                            <ImageView
                                android:layout_width="@dimen/home_quick_glyph_size"
                                android:layout_height="@dimen/home_quick_glyph_size"
                                android:layout_gravity="center"
                                android:contentDescription="@string/home_quick_extend"
                                android:src="@drawable/ic_home_extend_rental" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:gravity="center"
                            android:lineSpacingExtra="1dp"
                            android:text="@string/home_quick_extend"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Pending: vehicle carousel (Ellod Elite, Elacil 2.5) -->
                <HorizontalScrollView
                    android:id="@+id/cardAvailableVehicle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:clipToPadding="false"
                    android:scrollbars="none"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <LinearLayout
                        android:id="@+id/vehicleCarouselRow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingEnd="@dimen/spacing_sm" />
                </HorizontalScrollView>

                <!-- Rental alert -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:background="@drawable/bg_alert_warning"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_info"
                        android:drawablePadding="@dimen/spacing_sm"
                        android:gravity="center_vertical"
                        android:text="@string/home_rental_alert_title"
                        android:textColor="@color/alert_warning"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="@string/home_rental_alert_body"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/btnPayNow"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:background="@drawable/bg_button_outline_warning"
                        android:text="@string/home_pay_now"
                        android:textAllCaps="false"
                        android:textColor="@color/alert_warning"
                        app:backgroundTint="@null" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xl"
                    android:text="@string/home_quick_actions"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/rowSwapBattery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:background="@drawable/bg_home_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_lg">

                    <ImageView
                        android:layout_width="@dimen/home_quick_icon_size"
                        android:layout_height="@dimen/home_quick_icon_size"
                        android:background="@drawable/bg_circle_brand_soft"
                        android:contentDescription="@null"
                        android:padding="@dimen/spacing_sm"
                        android:src="@drawable/ic_home_battery_swap" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/home_swap_battery_title"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="@string/home_swap_battery_sub"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/rowNavigate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:background="@drawable/bg_home_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_lg">

                    <ImageView
                        android:layout_width="@dimen/home_quick_icon_size"
                        android:layout_height="@dimen/home_quick_icon_size"
                        android:background="@drawable/bg_circle_navigate_soft"
                        android:contentDescription="@null"
                        android:padding="@dimen/spacing_sm"
                        android:src="@drawable/ic_nav_navigate" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/home_navigate_title"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="@string/home_navigate_sub"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xl"
                    android:text="@string/home_todays_stats"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:layout_weight="1"
                        android:background="@drawable/bg_home_card"
                        android:minHeight="@dimen/home_stat_min_height"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/home_stat_distance"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/home_stat_distance_value"
                                android:textColor="@color/text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:layout_width="@dimen/home_stat_icon_size"
                                android:layout_height="@dimen/home_stat_icon_size"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_location"
                                app:tint="@color/action_navigate" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:drawableStart="@drawable/ic_trend_up"
                            android:drawablePadding="@dimen/spacing_xs"
                            android:gravity="center_vertical"
                            android:text="@string/home_stat_distance_trend_label"
                            android:textColor="@color/brand_primary"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_home_card"
                        android:minHeight="@dimen/home_stat_min_height"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/home_stat_earnings"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/home_stat_earnings_value"
                                android:textColor="@color/text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:layout_width="@dimen/home_stat_icon_size"
                                android:layout_height="@dimen/home_stat_icon_size"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_stat_earnings"
                                app:tint="@color/action_navigate" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:layout_weight="1"
                        android:background="@drawable/bg_home_card"
                        android:minHeight="@dimen/home_stat_min_height"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/home_stat_trips"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/home_stat_trips_value"
                                android:textColor="@color/text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:layout_width="@dimen/home_stat_icon_size"
                                android:layout_height="@dimen/home_stat_icon_size"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_trend_up"
                                app:tint="@color/action_navigate" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_home_card"
                        android:minHeight="@dimen/home_stat_min_height"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/home_stat_hours"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/home_stat_hours_value"
                                android:textColor="@color/text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:layout_width="@dimen/home_stat_icon_size"
                                android:layout_height="@dimen/home_stat_icon_size"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_stat_hours"
                                app:tint="@color/action_navigate" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:background="@drawable/bg_home_card"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/home_battery_health"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_badge_approved"
                            android:paddingHorizontal="@dimen/spacing_md"
                            android:paddingVertical="@dimen/spacing_sm"
                            android:text="@string/home_battery_good_badge"
                            android:textColor="@color/status_approved"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/home_battery_level"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableStart="@drawable/ic_nav_battery"
                            android:drawablePadding="@dimen/spacing_sm"
                            android:drawableTint="@color/brand_primary"
                            android:gravity="center_vertical"
                            android:text="@string/home_battery_level_value"
                            android:textColor="@color/brand_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/home_battery_est_range"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_battery_est_range_value"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/home_battery_last_swap"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_battery_last_swap_value"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/home_divider_height"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:background="@color/stroke_default" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="@string/home_battery_tip"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:layout_marginBottom="@dimen/spacing_lg"
                    android:background="@drawable/bg_home_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_lg">

                    <ImageView
                        android:layout_width="@dimen/home_quick_icon_size"
                        android:layout_height="@dimen/home_quick_icon_size"
                        android:background="@drawable/bg_circle_brand_soft"
                        android:contentDescription="@null"
                        android:padding="@dimen/spacing_sm"
                        android:src="@drawable/ic_check_circle" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/home_next_service_title"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="@string/home_next_service_body"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
